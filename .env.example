# Semgrep Cloud Platform
SEMGREP_APP_TOKEN=your_semgrep_token_here
SEMGREP_DEPLOYMENT_SLUG=your-org-slug          # e.g. "acme-corp" — used for /findings
SEMGREP_DEPLOYMENT_ID=12345                    # numeric ID — used for /secrets

# Monday.com — run `python setup_boards.py` to create boards and get IDs
MONDAY_API_TOKEN=your_monday_token_here
MONDAY_BOARD_ID_SAST=
MONDAY_BOARD_ID_SCA=
MONDAY_BOARD_ID_SECRETS=
